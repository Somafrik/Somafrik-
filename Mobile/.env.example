# Copier ce fichier vers .env.local puis adapter les valeurs.
# Les variables EXPO_PUBLIC_* sont injectées dans l'app au build / au démarrage Expo.

# URL du backend Somafrik (sans /api à la fin)
# - Émulateur Android sur PC : http://10.0.2.2:5000
# - Téléphone physique (même Wi‑Fi ou hotspot) : http://VOTRE_IP_LAN:5000
#   → ipconfig (Windows) : prendre l'IPv4 de la carte Wi‑Fi connectée au téléphone
# - Backend Docker sur la machine : http://localhost:5000
EXPO_PUBLIC_API_URL=http://localhost:5000

# Mode démo (données locales uniquement, sans API)
EXPO_PUBLIC_DEMO_MODE=false

# Port du serveur Metro (8081 par défaut ; changez si le port est occupé)
EXPO_PORT=8081

# IP LAN du PC pour Expo Go (obligatoire sur téléphone physique, remplace localhost dans le QR code)
# REACT_NATIVE_PACKAGER_HOSTNAME=10.69.112.170
