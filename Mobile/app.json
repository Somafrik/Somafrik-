{
  "expo": {
    "name": "Somafrik",
    "slug": "somafrik",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/somafrik-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/somafrik-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Somafrik utilise vos photos pour ajouter la photo du compte.",
          "cameraPermission": "Somafrik utilise l'appareil photo pour prendre la photo du compte."
        }
      ]
    ],
    "android": {
      "package": "com.somafrik.app",
      "versionCode": 12,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/somafrik-logo.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "ios": {
      "bundleIdentifier": "com.somafrik.app",
      "supportsTablet": true
    },
    "scheme": "somafrik"
  }
}
