# ── Somafrik — tout sur Docker (recommandé) ──
# Copier vers .env puis : npm run docker:up
# Script avec détection IP : powershell -ExecutionPolicy Bypass -File scripts\docker-up.ps1
#
# URLs :
#   API        http://localhost:5000/api/health
#   BackOffice http://localhost:5000/backoffice/
#   Web build  http://localhost:5000/web/
#   Web dev    http://localhost:5173/web/
#   Expo       port EXPO_PORT (défaut 8083) — npm run docker:logs:mobile
#
# Ne pas lancer npm run backend en parallèle (conflit port 5000).

NODE_ENV=production
BACKEND_PORT=5000
POSTGRES_HOST_PORT=5433
POSTGRES_DB=somafrik
POSTGRES_USER=somafrik
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-this-long-random-secret-before-use
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5173,http://127.0.0.1:5173,http://ADRESSE_IP_DU_PC:5000,http://ADRESSE_IP_DU_PC:5173,http://ADRESSE_IP_DU_PC:8083
WEB_DEV_PORT=5173
SOMAFRIK_DB_REQUIRED=true
JSON_BODY_LIMIT=1mb
EXPO_PORT=8083
REACT_NATIVE_PACKAGER_HOSTNAME=ADRESSE_IP_DU_PC
EXPO_PUBLIC_API_URL=http://ADRESSE_IP_DU_PC:5000
EXPO_PUBLIC_DEMO_MODE=false
