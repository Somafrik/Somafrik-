# ── Développement local sans Docker (recommandé si Docker consomme trop de RAM) ──
# Copier ces lignes dans .env.local à la racine :
# SOMAFRIK_DB_REQUIRED=false
# PORT=5000
# NODE_ENV=development
# Puis : npm run backend  (terminal 1)  +  npm run dev  (terminal 2)
# BackOffice : http://localhost:5173/web/
# Arrêter Docker : docker compose down

NODE_ENV=production
BACKEND_PORT=5000
POSTGRES_PORT=5432
POSTGRES_DB=somafrik
POSTGRES_USER=somafrik
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-this-long-random-secret-before-use
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8083,http://127.0.0.1:8083,http://ADRESSE_IP_DU_PC:8083
# Mettre CORS_ALLOW_DEV_ORIGINS=false pour désactiver l'ajout auto de localhost:5173 (Vite)
SOMAFRIK_DB_REQUIRED=true
JSON_BODY_LIMIT=1mb
EXPO_PORT=8082
REACT_NATIVE_PACKAGER_HOSTNAME=ADRESSE_IP_DU_PC
EXPO_PUBLIC_API_URL=http://ADRESSE_IP_DU_PC:5000
EXPO_PUBLIC_DEMO_MODE=false
