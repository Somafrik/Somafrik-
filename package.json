{
  "name": "somafrik-workspace",
  "private": true,
  "scripts": {
    "dev": "npm --prefix web run dev",
    "start": "npm --prefix backend run dev:memory",
    "backend": "npm --prefix backend run dev:memory",
    "backend:memory": "npm --prefix backend run dev:memory",
    "backend:pg": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "mobile": "npm --prefix Mobile run start --",
    "mobile:lan": "npm --prefix Mobile run start:lan --",
    "mobile:tunnel": "npm --prefix Mobile run start:tunnel --",
    "mobile:clear": "npm --prefix Mobile run start:clear --",
    "mobile:web": "npm --prefix Mobile run web",
    "mobile:android": "npm --prefix Mobile run android",
    "mobile:ios": "npm --prefix Mobile run ios",
    "check": "node -c backend/server.js && node -c backend/db/postgresRepository.js && node --check BackOffice/app.js && cd Mobile && npx tsc --noEmit",
    "check:api": "node scripts/verify-api-connections.js",
    "check:suspension": "node scripts/verify-suspension.js",
    "sync:env": "powershell -ExecutionPolicy Bypass -File scripts/sync-env.ps1",
    "web:build": "npm --prefix web run build",
    "web:dev": "npm --prefix web run dev",
    "docker:up": "docker compose up -d --build",
    "docker:up:core": "docker compose up -d --build postgres backend",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:logs:backend": "docker compose logs -f backend",
    "docker:logs:mobile": "docker compose logs -f mobile",
    "docker:logs:web": "docker compose logs -f web-dev",
    "docker:build": "docker compose build backend",
    "mobile:docker": "powershell -ExecutionPolicy Bypass -File scripts/mobile-docker-connect.ps1",
    "mobile:host": "powershell -ExecutionPolicy Bypass -File scripts/mobile-host-expo.ps1",
    "mobile:host:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/mobile-host-expo.ps1 -Tunnel",
    "firewall:dev": "powershell -ExecutionPolicy Bypass -File scripts/open-firewall-dev.ps1"
  }
}
